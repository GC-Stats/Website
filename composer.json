{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "gc-stats/website",
    "type": "project",
    "description": "The official website of the GC-Stats project.",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "intervention/image-laravel": "^4.0",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^13.6.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.28",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.2",
        "livewire/volt": "^1.10",
        "owenvoke/blade-fontawesome": "^3.2",
        "platformcommunity/flysystem-bunnycdn": "^3.3",
        "predis/predis": "^3.4",
        "socialiteproviders/discord": "^4.2",
        "socialiteproviders/twitch": "^5.4",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-permission": "^8.3",
        "spatie/laravel-sitemap": "^8.1",
        "symfony/css-selector": "^8.0",
        "symfony/dom-crawler": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "fruitcake/laravel-debugbar": "^4.2",
        "laravel/boost": "^2.2",
        "laravel/dusk": "^8.6",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "analyse": [
            "phpstan analyse --memory-limit=1G"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@analyse",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.4"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
